# Copie para .env — local (Docker+MySQL) ou produção (Supabase PostgreSQL)
APP_ENV=local

# --- Local Docker (docker compose up) ---
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=sistema_labs
# DB_USERNAME=root
# DB_PASSWORD=root

# --- Produção Supabase (Render / Docker nuvem) ---
DB_CONNECTION=pgsql
DB_HOST=aws-1-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_SSLMODE=require
DB_DATABASE=postgres
DB_USERNAME=postgres.eqawtpbvcqlcemysjkox
DB_PASSWORD=

# Google OAuth (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://labhub-uniceplac.onrender.com/login_google.php

# URL pública do app (links em e-mails)
# APP_URL=https://labhub-uniceplac.onrender.com

